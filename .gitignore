/.next/
/out/
frontend/.next/
frontend/out/

# production
/build
dist/

# misc
.DS_Store
*.pem
*.log
logs/
.cache/
.turbo/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
