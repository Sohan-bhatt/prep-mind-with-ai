# =============================================================
# UPSC Learning Hub — Environment Variables
# =============================================================
# Copy this file to .env and fill in the values.

# ---- FastAPI Backend URL ----
# For local dev: http://127.0.0.1:8000
# For production (Render): https://your-backend.onrender.com
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"

# ---- Gemini API Key (server-side fallback) ----
# Optional. If set, the server uses this key when the user hasn't provided one.
# Users can always supply their own key via the Settings panel in the UI.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ---- Database (Prisma / LibSQL) ----
# For local dev with SQLite, no value needed (defaults to file:./dev.db)
# For production with Turso (recommended for Vercel):
#   DATABASE_URL="libsql://your-db.turso.io"
#   DATABASE_AUTH_TOKEN="your-token"
DATABASE_URL=""
DATABASE_AUTH_TOKEN=""

# =============================================================
# Vercel Deployment Checklist
# =============================================================
# 1. Push this repo to GitHub
# 2. Import the repo in vercel.com → New Project
# 3. Set the environment variables above in Vercel Project Settings
# 4. Deploy the FastAPI backend to Render (see backend/README or render.yaml)
# 5. Set NEXT_PUBLIC_API_URL to your Render backend URL in Vercel
# 6. (Optional) Set GEMINI_API_KEY as a Vercel env var so it acts as default for
#    users who haven't added their own key yet.
#
# Note: Users can enter their own Gemini API key in the Settings panel (☰ icon,
# top-left). Their key is stored in localStorage — it never reaches your server.
